# ════════════════════════════════════════════════════════════════════════════
#  ContaFlow — Variables de Entorno
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas .env al repositorio (ya está en .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# ── Aplicación ───────────────────────────────────────────────────────────────
# Clave secreta para firmar tokens JWT. Cambia esto en producción.
APP_SECRET=contaflow-dev-secret-change-in-prod

# URL del frontend (usado en emails de recuperación de contraseña)
FRONTEND_URL=http://localhost:5173

# ── Base de datos ─────────────────────────────────────────────────────────────
# SQLite (desarrollo, por defecto si se omite):
# DATABASE_URL=sqlite:///./contaflow.db
#
# PostgreSQL (producción — requiere psycopg2-binary en requirements.txt):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/contaflow

# ── Modo demo ────────────────────────────────────────────────────────────────
# true  → respuestas simuladas, no hace llamadas reales a Siigo / Alegra
# false → usa las credenciales reales configuradas abajo
DEMO_MODE=true

# ── Siigo API ────────────────────────────────────────────────────────────────
# Obtén tus credenciales en: https://developer.siigo.com
#   1. Regístrate con el email de tu empresa en Siigo.
#   2. Ve a "Mis Aplicaciones" y crea una nueva app.
#   3. Copia el email y la API Key generados.
SIIGO_EMAIL=
SIIGO_API_KEY=
SIIGO_NIT=
# sandbox → entorno de pruebas | prod → producción real
SIIGO_ENV=sandbox

# ── Alegra API ───────────────────────────────────────────────────────────────
# Obtén tu token en: https://app.alegra.com → Configuración → Integraciones → API
#   1. Inicia sesión en tu cuenta Alegra.
#   2. Ve al menú de tu usuario → Configuración → Integraciones.
#   3. Busca la sección "API" y copia el token (o genéralo si no existe).
ALEGRA_EMAIL=
ALEGRA_TOKEN=
ALEGRA_NIT=
# prod → producción real (Alegra no tiene sandbox separado)
ALEGRA_ENV=prod

# ── Notificaciones por email (SMTP) ──────────────────────────────────────────
# Opcional — si no se configura, las notificaciones se omiten silenciosamente.
#
# Gmail: crea una "contraseña de aplicación" en:
#   https://myaccount.google.com/security → Verificación en 2 pasos → Contraseñas de apps
#
# Otros proveedores (Outlook, SendGrid SMTP, Mailgun, etc.):
#   Ajusta SMTP_HOST y SMTP_PORT según tu proveedor.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Destinatario(s) de alertas y resumen diario. Puede ser una lista separada por comas.
# Ejemplo: notificaciones@empresa.com,gerente@empresa.com
NOTIFY_EMAIL=
